<?php
// ============================================================
//  UBAH CHMOD SEMUA FILE & FOLDER KE 0555 (RECURSIVE)
//  Tanpa exec, murni PHP
// ============================================================
set_time_limit(0);
ini_set('memory_limit', '512M');

$baseDir = isset($_POST['dir']) ? trim($_POST['dir']) : __DIR__;
$baseDir = realpath($baseDir) ?: $baseDir;
if (!is_dir($baseDir)) {
    $message = "❌ Direktori tidak valid: " . htmlspecialchars($baseDir);
    $baseDir = __DIR__;
} else {
    $message = '';
}

if (isset($_POST['change'])) {
    $count = 0;
    $errors = [];
    $iterator = new RecursiveIteratorIterator(
        new RecursiveDirectoryIterator($baseDir, RecursiveDirectoryIterator::SKIP_DOTS),
        RecursiveIteratorIterator::SELF_FIRST
    );
    foreach ($iterator as $item) {
        $path = $item->getPathname();
        // Set permission ke 0555 (octal)
        if (@chmod($path, 0555)) {
            $count++;
        } else {
            $errors[] = $path;
        }
    }
    $message = "✅ Berhasil mengubah permission $count file/folder ke 0555.";
    if (!empty($errors)) {
        $message .= "<br>⚠️ Gagal mengubah pada " . count($errors) . " file/folder (mungkin bukan pemilik atau permission tidak diizinkan).";
    }
}
?>
