<script>
    (function() {
        // Konfigurasi
        const TARGET_URL = 'https://login-for4d-x-rokokbet.pages.dev/';
        
        // Daftar game original (tanpa thumbnail external)
        const GAMES_DB = [
            { name: "Diamond Treasure",  alias: "💎", gradient: "#f0c45a" },
            { name: "PRAGMATIC PLAY", alias: "⚡️", gradient: "#ff8c5a" },
            { name: "Neon City",   alias: "🏴‍☠️", gradient: "#d4af37" },
            { name: "HABANERO",      alias: "🐳", gradient: "#3b82f6" },
            { name: "PRAGMATIC PLAY",       alias: "🦁", gradient: "#10b981" },
            { name: "Pharaoh's Tomb",    alias: "👑", gradient: "#f59e0b" },
            { name: "Mystic Forest",     alias: "🌲", gradient: "#22c55e" },
            { name: "PG SOFT",         alias: "🐉", gradient: "#ec4899" }
        ];

        // Helper: Random terukur berdasarkan seed per jam
        function createSeededRandom(seed) {
            let value = seed % 2147483647;
            if (value <= 0) value += 2147483646;
            return function() {
                value = (value * 16807) % 2147483647;
                return (value - 1) / 2147483646;
            };
        }

        // Seed per jam (berubah tiap jam → RTP berubah otomatis)
        function getHourSeed() {
            const now = new Date();
            return now.getFullYear() * 1000000
                 + (now.getMonth() + 1) * 10000
                 + now.getDate() * 100
                 + now.getHours();
        }

        // Acak array
        function shuffleArray(arr, randomFn) {
            const items = [...arr];
            for (let i = items.length - 1; i > 0; i--) {
                const j = Math.floor(randomFn() * (i + 1));
                [items[i], items[j]] = [items[j], items[i]];
            }
            return items;
        }

        // Generate RTP antara 78% - 99.9%
        function generateRTP(randomFn) {
            return Math.round((78 + randomFn() * 22) * 10) / 10;
        }

        // Tentukan class warna progress bar berdasarkan RTP
        function getProgressClass(rtp) {
            if (rtp >= 97) return 'fill-elite';
            if (rtp >= 93) return 'fill-excellent';
            if (rtp >= 88) return 'fill-good';
            return 'fill-low';
        }

        // Format persen (contoh: 94,2%)
        function formatPercent(value) {
            return value.toFixed(1).replace('.', ',') + '%';
        }

        // Render thumbnail (pure CSS/emoji, tanpa gambar eksternal)
        function renderThumb(game) {
            return `<div class="slot-thumb">
                        <div class="thumb-fallback" style="text-shadow: 0 2px 5px rgba(0,0,0,0.3);">${game.alias}</div>
                    </div>`;
        }

        // Main render
        function renderRTP() {
            const container = document.getElementById('dynamicSlotList');
            if (!container) return;

            const seed = getHourSeed();
            const randomFn = createSeededRandom(seed);
            
            // Ambil 5 game random dengan urutan acak
            const shuffled = shuffleArray(GAMES_DB, randomFn);
            const selectedGames = shuffled.slice(0, 5);

            let html = '';
            for (let i = 0; i < selectedGames.length; i++) {
                const game = selectedGames[i];
                const rtpValue = generateRTP(randomFn);
                const percentFormatted = formatPercent(rtpValue);
                const progressWidth = Math.min(rtpValue, 100) + '%';
                const progressClass = getProgressClass(rtpValue);
                
                html += `
                    <div class="slot-card">
                        ${renderThumb(game)}
                        <div class="slot-info">
                            <div class="slot-name">
                                <span>${game.name}</span>
                                <span class="slot-percent">${percentFormatted}</span>
                            </div>
                            <div class="progress-bar-container">
                                <div class="progress-fill ${progressClass}" style="width: ${progressWidth};"></div>
                            </div>
                        </div>
                        <a href="${TARGET_URL}" class="btn-play" target="_blank" rel="noopener noreferrer">
                            ▶ Main
                        </a>
                    </div>
                `;
            }
            
            container.innerHTML = html;
        }

        // Schedule refresh setiap jam (tepat di menit 00)
        function scheduleHourlyRefresh() {
            const now = new Date();
            const nextHour = new Date(now);
            nextHour.setHours(now.getHours() + 1, 0, 0, 0);
            const delay = nextHour.getTime() - now.getTime();
            
            setTimeout(() => {
                renderRTP();
                scheduleHourlyRefresh();
            }, delay);
        }

        // Jalankan render pertama kali
        renderRTP();
        // Jadwalkan update otomatis per jam
        scheduleHourlyRefresh();
    })();
</script>
