<script>
    // Data konfigurasi pasaran ORIGINAL
    const markets = [
        { name: "MACAU", code: "macau", badge: "4D", times: ["00:01","13:00","16:00","19:00","22:00","23:00"], desc: "6x setiap hari" },
        { name: "HONGKONG", code: "hk", badge: "HK", times: ["23:15"], desc: "Setiap hari" },
        { name: "SYDNEY", code: "sydney", badge: "SDY", times: ["14:05"], desc: "Setiap hari" },
        { name: "SINGAPORE", code: "sgp", badge: "SGP", times: ["17:45"], desc: "Selasa & Jumat libur" },
        { name: "KINGKONG", code: "kingkong", badge: "4D", times: ["17:00","23:30"], desc: "2x setiap hari" }
    ];

    // Helper: hitung detik hingga jadwal berikutnya
    function getSecondsUntil(targetHour, targetMinute, now) {
        let target = targetHour * 3600 + targetMinute * 60;
        let current = now.getHours() * 3600 + now.getMinutes() * 60 + now.getSeconds();
        let diff = target - current;
        if (diff < 0) diff += 86400;
        return diff;
    }

    // Format detik ke HH:MM:SS
    function formatTime(seconds) {
        if (seconds <= 0) return "00:00:00";
        const h = Math.floor(seconds / 3600).toString().padStart(2, '0');
        const m = Math.floor((seconds % 3600) / 60).toString().padStart(2, '0');
        const s = (seconds % 60).toString().padStart(2, '0');
        return `${h}:${m}:${s}`;
    }

    // Cek apakah Singapore libur (Selasa = 2, Jumat = 5)
    function isSingaporeHoliday(now) {
        const day = now.getDay(); // Minggu=0, Senin=1, Selasa=2, Jumat=5
        return (day === 2 || day === 5);
    }

    // Hitung countdown untuk tiap market
    function calculateCountdown(market, now) {
        if (market.code === "sgp" && isSingaporeHoliday(now)) {
            return { status: "libur", display: "LIBUR" };
        }
        
        let targetSeconds = null;
        for (let timeStr of market.times) {
            const [hour, minute] = timeStr.split(":").map(Number);
            const secTarget = getSecondsUntil(hour, minute, now);
            if (targetSeconds === null || secTarget < targetSeconds) {
                targetSeconds = secTarget;
            }
        }
        return { status: "active", seconds: targetSeconds, display: formatTime(targetSeconds) };
    }

    // Render semua card
    function renderCountdowns() {
        const container = document.getElementById('scheduleGrid');
        if (!container) return;
        
        const now = new Date(new Date().toLocaleString("en-US", { timeZone: "Asia/Jakarta" }));
        
        let html = '';
        for (let market of markets) {
            const count = calculateCountdown(market, now);
            let timerHtml = '';
            if (count.status === 'libur') {
                timerHtml = `<div class="market-timer" style="color:#ff8866; font-size:2rem;">⛔ LIBUR</div>`;
            } else {
                timerHtml = `<div class="market-timer" data-code="${market.code}" data-sec="${count.seconds}">${count.display}</div>`;
            }
            
            html += `
                <div class="market-card">
                    <div class="market-header">
                        <span class="market-badge">${market.badge}</span>
                        <span class="market-name">${market.name}</span>
                    </div>
                    ${timerHtml}
                    <div class="market-schedule">
                        🕒 Jadwal: ${market.times.join(' / ')}<br>
                        📌 ${market.desc}
                    </div>
                </div>
            `;
        }
        
        container.innerHTML = html;
        
        // Update timer setiap detik (hanya untuk yang aktif)
        if (window.countdownInterval) clearInterval(window.countdownInterval);
        
        window.countdownInterval = setInterval(() => {
            const nowLive = new Date(new Date().toLocaleString("en-US", { timeZone: "Asia/Jakarta" }));
            for (let market of markets) {
                if (market.code === "sgp" && isSingaporeHoliday(nowLive)) {
                    const timerDiv = document.querySelector(`.market-timer[data-code="${market.code}"]`);
                    if (timerDiv && timerDiv.innerText !== "LIBUR") {
                        timerDiv.innerText = "LIBUR";
                        timerDiv.style.color = "#ff8866";
                    }
                    continue;
                }
                
                let targetSeconds = null;
                for (let timeStr of market.times) {
                    const [hour, minute] = timeStr.split(":").map(Number);
                    const secTarget = getSecondsUntil(hour, minute, nowLive);
                    if (targetSeconds === null || secTarget < targetSeconds) {
                        targetSeconds = secTarget;
                    }
                }
                
                if (targetSeconds !== null) {
                    const timerDiv = document.querySelector(`.market-timer[data-code="${market.code}"]`);
                    if (timerDiv && targetSeconds > 0) {
                        timerDiv.innerText = formatTime(targetSeconds);
                        timerDiv.setAttribute('data-sec', targetSeconds);
                    }
                }
            }
        }, 1000);
    }

    renderCountdowns();
</script>


