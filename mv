<?php
// ============================================================
//  PINDAHKAN SEMUA FILE DARI ojs-3.3.0-13 KE ROOT
//  Tanpa exec, murni PHP
// ============================================================
set_time_limit(0);

$src = __DIR__ . '/ojs-3.3.0-13';
$dest = __DIR__; // root web

$message = '';

if (isset($_POST['move'])) {
    if (!is_dir($src)) {
        $message = "❌ Sumber folder tidak ditemukan: " . htmlspecialchars($src);
    } else {
        $overwrite = isset($_POST['overwrite']);
        $count = 0;
        $errors = [];

        // --- Pindahkan semua file & folder ---
        $iterator = new RecursiveIteratorIterator(
            new RecursiveDirectoryIterator($src, RecursiveDirectoryIterator::SKIP_DOTS),
            RecursiveIteratorIterator::SELF_FIRST
        );

        foreach ($iterator as $item) {
            $relPath = substr($item->getPathname(), strlen($src) + 1);
            $target = $dest . '/' . $relPath;

            if ($item->isDir()) {
                if (!is_dir($target)) {
                    mkdir($target, 0777, true);
                }
            } else {
                // File
                if (file_exists($target) && !$overwrite) {
                    $errors[] = "Lewati: $relPath (tujuan sudah ada)";
                    continue;
                }
                if (rename($item->getPathname(), $target)) {
                    $count++;
                } else {
                    $errors[] = "Gagal memindahkan: $relPath";
                }
            }
        }

        // --- Bersihkan folder sumber (hapus semua subfolder & file yang tersisa) ---
        $iterator2 = new RecursiveIteratorIterator(
            new RecursiveDirectoryIterator($src, RecursiveDirectoryIterator::SKIP_DOTS),
            RecursiveIteratorIterator::CHILD_FIRST
        );
        foreach ($iterator2 as $item) {
            if ($item->isDir()) {
                @rmdir($item->getPathname());
            } else {
                @unlink($item->getPathname());
            }
        }
        @rmdir($src); // hapus folder WordPress-7.0.2
        @rmdir(__DIR__ . '/wordpress'); // hapus folder wordpress jika kosong

        $message = "✅ Berhasil memindahkan $count file.";
        if (!empty($errors)) {
            $message .= "<br>⚠️ " . implode('<br>', $errors);
        }
    }
}
?>
